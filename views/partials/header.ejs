<header class="header">
    <div class="header-inner">

        <a href="/" class="logo">
            <img src="/public/image/logo.webp" alt="SW Helper">
        </a>
        <div class="search-container" id="headerSearchWrapper">
            <input type="text" class="search-input" id="headerSearchInput" placeholder="몬스터 이름 검색..." autocomplete="off">
            <button type="button" class="search-btn" id="headerSearchBtn" aria-label="검색">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
            </button>
            <div id="headerSuggestions" class="suggestions-list"></div>
        </div>
        <button class="menu-toggle" id="menuToggle" aria-label="메뉴">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>
</header>

<div class="menu-overlay" id="menuOverlay"></div>

<nav class="side-menu" id="sideMenu">
    <!-- 일반 메뉴 -->
    <div class="menu-wrapper" id="normalMenu">
        <ul class="menu-list">
            <% if (user?.level === 99) { %>
                <li class="menu-item">
                    <a href="/admin" class="menu-link">관리자 모드</a>
                </li>
                <li class="menu-item menu-divider"></li>
            <% } %>
            <% if (user) { %>
                <li class="menu-item">
                    <a href="/mypage" class="menu-link">마이페이지</a>
                </li>
            <% } %>
            <li class="menu-item">
                <a href="/game" class="menu-link">방덱 리스트</a>
            </li>
            <li class="menu-item">
                <a href="/game/monster" class="menu-link">몬스터</a>
            </li>
        </ul>
        <ul class="menu-list menu-bottom">
            <% if (user) { %>
                <li class="menu-item">
                    <a href="/api/auth/logout" class="menu-link logout-link">로그아웃</a>
                </li>
            <% } else { %>
                <li class="menu-item">
                    <a href="/auth/login" class="menu-link login-link">로그인</a>
                </li>
            <% } %>
        </ul>
    </div>

    <!-- 관리자 메뉴 -->
    <div class="menu-wrapper" id="adminMenu" style="display:none;">
        <ul class="menu-list">
            <li class="menu-item">
                <a href="/" class="menu-link">사용자 모드</a>
            </li>
            <li class="menu-item menu-divider"></li>
            <li class="menu-item">
                <a href="/admin" class="menu-link">대시보드</a>
            </li>
            <li class="menu-item">
                <a href="/admin/defence" class="menu-link">방덱관리</a>
            </li>
            <li class="menu-item">
                <a href="/admin/member" class="menu-link">회원관리</a>
            </li>
            <li class="menu-item">
                <a href="/admin/code" class="menu-link">코드관리</a>
            </li>
            <li class="menu-item">
                <a href="/admin/monster" class="menu-link">몬스터관리</a>
            </li>
        </ul>
    </div>
</nav>

<script>
(function() {
    const menuToggle = document.getElementById('menuToggle');
    const sideMenu = document.getElementById('sideMenu');
    const menuOverlay = document.getElementById('menuOverlay');
    const normalMenu = document.getElementById('normalMenu');
    const adminMenu = document.getElementById('adminMenu');

    // /admin 경로인 경우 관리자 메뉴 표시
    const isAdminPage = window.location.pathname.startsWith('/admin');
    if (isAdminPage) {
        normalMenu.style.display = 'none';
        adminMenu.style.display = 'block';
    }

    function toggleMenu() {
        menuToggle.classList.toggle('active');
        sideMenu.classList.toggle('open');
        menuOverlay.classList.toggle('show');
        document.body.style.overflow = sideMenu.classList.contains('open') ? 'hidden' : '';
    }

    function closeMenu() {
        menuToggle.classList.remove('active');
        sideMenu.classList.remove('open');
        menuOverlay.classList.remove('show');
        document.body.style.overflow = '';
    }

    menuToggle.addEventListener('click', toggleMenu);
    menuOverlay.addEventListener('click', closeMenu);

    // ESC 키로 메뉴 닫기
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && sideMenu.classList.contains('open')) {
            closeMenu();
        }
    });

    // 로그아웃 링크 클릭 시 처리
    const logoutLinks = document.querySelectorAll('.logout-link');
    logoutLinks.forEach(link => {
        link.addEventListener('click', async (e) => {
            e.preventDefault();
            try {
                await fetch('/api/auth/logout', { method: 'GET' });
                window.location.href = '/auth/login';
            } catch (error) {
                console.error('Logout error:', error);
                window.location.href = '/auth/login';
            }
        });
    });

    // 헤더 검색 기능
    const headerSearchInput = document.getElementById('headerSearchInput');
    const headerSuggestions = document.getElementById('headerSuggestions');
    const headerSearchBtn = document.getElementById('headerSearchBtn');
    const headerSearchWrapper = document.getElementById('headerSearchWrapper');
    let headerDebounceTimer;

    if (headerSearchInput && headerSearchBtn) {
        // 현재 URL이 /game/defence이고 keyword 파라미터가 있으면 초기화
        const urlParams = new URLSearchParams(window.location.search);
        const keyword = urlParams.get('keyword');
        if (window.location.pathname === '/game/defence' || window.location.pathname === '/game/defence/') {
            if (keyword) {
                headerSearchInput.value = keyword;
            }
        }

        headerSearchInput.addEventListener('input', (e) => {
            clearTimeout(headerDebounceTimer);
            const kw = e.target.value.trim();

            if (kw.length >= 1) {
                headerDebounceTimer = setTimeout(() => fetchHeaderSuggestions(kw), 200);
            } else {
                headerSuggestions.classList.remove('active');
            }
        });

        headerSearchInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                headerSuggestions.classList.remove('active');
                executeHeaderSearch();
            }
        });

        headerSearchBtn.addEventListener('click', () => {
            headerSuggestions.classList.remove('active');
            executeHeaderSearch();
        });

        document.addEventListener('click', (e) => {
            if (headerSearchWrapper && !headerSearchWrapper.contains(e.target)) {
                headerSuggestions.classList.remove('active');
            }
        });

        async function fetchHeaderSuggestions(kw) {
            try {
                const response = await fetch(`/api/game/monster/suggest?keyword=${encodeURIComponent(kw)}`, {
                    credentials: 'include'
                });
                const data = await response.json();
                renderHeaderSuggestions(data.suggestions);
            } catch (error) {
                console.error('Failed to fetch suggestions:', error);
            }
        }

        function renderHeaderSuggestions(suggestions) {
            if (!suggestions || suggestions.length === 0) {
                headerSuggestions.classList.remove('active');
                return;
            }

            headerSuggestions.innerHTML = suggestions.map(name =>
                `<div class="suggestion-item" data-name="${name}">${name}</div>`
            ).join('');
            headerSuggestions.classList.add('active');

            headerSuggestions.querySelectorAll('.suggestion-item').forEach(item => {
                item.addEventListener('click', () => {
                    headerSearchInput.value = item.dataset.name;
                    headerSuggestions.classList.remove('active');
                    executeHeaderSearch();
                });
            });
        }

        function executeHeaderSearch() {
            const kw = headerSearchInput.value.trim();
            const url = kw
                ? `/game/defence?keyword=${encodeURIComponent(kw)}`
                : '/game/defence';
            window.location.href = url;
        }
    }
})();
</script>
