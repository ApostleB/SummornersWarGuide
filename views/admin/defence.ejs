<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/public/favicon.ico" type="image/x-icon">
    <title>관리자 - 덱 관리</title>
    <link rel="stylesheet" href="/public/css/common/layout.css">
    <link rel="stylesheet" href="/public/css/style.css">
    <link rel="stylesheet" href="/public/css/admin.css">
    <link rel="stylesheet" href="/public/css/admin/game.css">
</head>
<body>
<%- include('../partials/header') %>

<main class="main-content">
    <div class="admin-container">
        <div class="page-header">
            <h1 class="page-title">덱 관리</h1>
            <p class="page-desc">방어 덱을 관리합니다</p>
        </div>
        <div class="header-actions">
            <div class="search-container">
                <input type="text" class="search-input" id="searchInput" placeholder="몬스터 이름 검색..." autocomplete="off">
                <button type="button" class="reset-btn" id="resetBtn" aria-label="초기화" style="display: none;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
                <button type="button" class="search-btn" id="searchBtn" aria-label="검색">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"></circle>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                    </svg>
                </button>
            </div>
            <div class="btn-group">
                <input type="file" id="fileInput" accept=".xlsx,.xls,.csv" style="display:none;">
                <button id="uploadSheet" class="fileBtn uploadExcel" type="button">업로드</button>
                <button id="downloadSheet" class="fileBtn downloadExcel" type="button">다운로드</button>
            </div>
        </div>
    </div>

    <div class="admin-container">
        <div id="defenceList"></div>
    </div>
</main>

<!-- 롱프레스 팝업 -->
<div class="monster-popup" id="monsterPopup">
    <div class="monster-popup-title">방어덱 구성</div>
    <div class="monster-popup-list" id="monsterPopupList"></div>
</div>

<script>
    // 검색 기능
    const searchInput = document.getElementById('searchInput');
    const searchBtn = document.getElementById('searchBtn');
    const resetBtn = document.getElementById('resetBtn');

    searchInput.addEventListener('input', () => {
        resetBtn.style.display = searchInput.value.length > 0 ? 'flex' : 'none';
    });

    searchInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') fetchDefenceList();
    });
    searchBtn.addEventListener('click', () => fetchDefenceList());

    resetBtn.addEventListener('click', () => {
        searchInput.value = '';
        resetBtn.style.display = 'none';
        fetchDefenceList();
        searchInput.focus();
    });

    // 파일 업로드 기능
    const fileInput = document.getElementById('fileInput');
    const uploadBtn = document.getElementById('uploadSheet');

    uploadBtn.addEventListener('click', () => {
        fileInput.click();
    });

    fileInput.addEventListener('change', async (e) => {
        const file = e.target.files[0];
        if (!file) return;

        const formData = new FormData();
        formData.append('file', file);

        try {
            uploadBtn.disabled = true;
            uploadBtn.textContent = '업로드 중...';

            const response = await fetch('/api/admin/file/defence', {
                method: 'POST',
                credentials: 'include',
                body: formData
            });

            const data = await response.json();

            if (response.ok) {
                alert('업로드가 완료되었습니다.');
                fetchDefenceList();
            } else {
                alert(data.message || '업로드에 실패했습니다.');
            }
        } catch (error) {
            console.error('Failed to upload file:', error);
            alert('업로드 중 오류가 발생했습니다.');
        } finally {
            uploadBtn.disabled = false;
            uploadBtn.textContent = '업로드';
            fileInput.value = '';
        }
    });

    async function fetchDefenceList() {
        try {
            const keyword = searchInput.value.trim();
            const apiUrl = keyword
                ? `/api/game/defence?keyword=${encodeURIComponent(keyword)}`
                : '/api/game/defence';

            const response = await fetch(apiUrl, {
                method: 'GET',
                credentials: 'include'
            });
            const data = await response.json();
            renderDefenceList(data.defenceList);
        } catch (error) {
            console.error('Failed to fetch defence list:', error);
        }
    }

    function renderDefenceList(defenceList) {
        const container = document.getElementById('defenceList');
        if (!defenceList || defenceList.length === 0) {
            container.innerHTML = '<div class="no-results">검색 결과가 없습니다.</div>';
            return;
        }

        container.innerHTML = defenceList.map(defence => `
            <div class="defence-card admin-card defence-card-admin" id="card-${defence.defenceId}" data-id="${defence.defenceId}">
                <div class="card-header-wrapper" onclick="toggleAdminAccordion('${defence.defenceId}')">
                    <div class="card-content">
                        <div class="monster-deck" data-defence='${JSON.stringify({
                            monsterA: defence.defenceMonsterA,
                            monsterB: defence.defenceMonsterB,
                            monsterC: defence.defenceMonsterC
                        }).replace(/'/g, "&#39;")}'>
                            ${renderMonster(defence.defenceMonsterA)}
                            ${renderMonster(defence.defenceMonsterB)}
                            ${renderMonster(defence.defenceMonsterC)}
                        </div>
                    </div>
                    <div class="card-info-actions">
                        <span class="attack-count">공략 ${defence.attackCount}건</span>
                        <div class="card-actions" onclick="event.stopPropagation()">
                            <button class="action-btn delete-btn" onclick="deleteDefence('${defence.defenceId}')">삭제</button>
                        </div>
                        <span class="chevron" id="chevron-${defence.defenceId}">▼</span>
                    </div>
                </div>
                <div class="accordion-body" id="body-${defence.defenceId}">
                    <div class="admin-attack-list" id="attack-list-${defence.defenceId}">
                        <div class="loading-inline">공략 정보를 불러오는 중...</div>
                    </div>
                </div>
            </div>
        `).join('');
    }

    async function toggleAdminAccordion(defenceId) {
        const card = document.getElementById(`card-${defenceId}`);
        const body = document.getElementById(`body-${defenceId}`);
        const chevron = document.getElementById(`chevron-${defenceId}`);
        const isOpen = card.classList.contains('open');

        if (isOpen) {
            card.classList.remove('open');
            body.style.maxHeight = '0px';
            chevron.style.transform = 'rotate(0deg)';
        } else {
            card.classList.add('open');
            body.style.maxHeight = body.scrollHeight + 'px';
            chevron.style.transform = 'rotate(180deg)';

            // 데이터가 로딩 전이라면 불러오기
            const listContainer = document.getElementById(`attack-list-${defenceId}`);
            if (listContainer.querySelector('.loading-inline')) {
                fetchAttackList(defenceId);
            }
        }
    }

    async function fetchAttackList(defenceId) {
        try {
            const response = await fetch(`/api/game/defence/${defenceId}`, { credentials: 'include' });
            const data = await response.json();
            renderAttackList(defenceId, data.attackList);

            // 내용물 길이에 맞춰 max-height 재조정
            const card = document.getElementById(`card-${defenceId}`);
            const body = document.getElementById(`body-${defenceId}`);
            if (card.classList.contains('open')) {
                body.style.maxHeight = body.scrollHeight + 'px';
            }
        } catch (error) {
            document.getElementById(`attack-list-${defenceId}`).innerHTML = '<div class="no-results">공략 정보를 불러오지 못했습니다.</div>';
        }
    }

    function renderAttackList(defenceId, attackList) {
        const container = document.getElementById(`attack-list-${defenceId}`);
        if (!attackList || attackList.length === 0) {
            container.innerHTML = '<div class="no-results">등록된 공략이 없습니다.</div>';
            return;
        }

        container.innerHTML = attackList.map((attack, index) => `
            <div class="attack-item-admin" id="attack-item-${attack.attackId}">
                <div class="attack-view-mode" id="attack-view-${attack.attackId}">
                    <div class="attack-view-wrapper">
                        <div class="attack-header-row">
                            <span class="attack-index">#${index + 1}</span>
                            <div class="attack-meta">
                                <span class="attack-meta-item">
                                    <span class="meta-label created">작성</span>
                                    <span class="meta-name">${attack.inputMember?.name || attack.inputMember?.nickname || '-'}</span>
                                    <span class="meta-date">${attack.inputDt ? new Date(attack.inputDt).toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\\. /g, '.').replace(/\\.$/, '') : ''}</span>
                                </span>
                                ${attack.updateMember ? `
                                <span class="attack-meta-item">
                                    <span class="meta-label updated">수정</span>
                                    <span class="meta-name">${attack.updateMember?.name || attack.updateMember?.nickname || '-'}</span>
                                    <span class="meta-date">${attack.updateDt ? new Date(attack.updateDt).toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\\. /g, '.').replace(/\\.$/, '') : ''}</span>
                                </span>
                                ` : ''}
                            </div>
                        </div>
                        <div class="attack-monsters">
<!--                            <span class="attack-index">#${index + 1}</span>-->
                            ${renderMonster(attack.attackMonsterA)}
                            ${renderMonster(attack.attackMonsterB)}
                            ${renderMonster(attack.attackMonsterC)}
                        </div>
                        <div class="attack-body-row">
                            <div class="attack-desc-list">
                                ${attack.deckDesc1 ? `<div class="attack-desc-item"><strong>비고1:</strong> ${attack.deckDesc1}</div>` : ''}
                                ${attack.deckDesc2 ? `<div class="attack-desc-item"><strong>비고2:</strong> ${attack.deckDesc2}</div>` : ''}
                                ${!attack.deckDesc1 && !attack.deckDesc2 ? '<div class="attack-desc-empty">설명 없음</div>' : ''}
                            </div>
                            <div class="attack-view-actions">
                                <button class="action-btn edit-btn" onclick="enableAttackEdit('${attack.attackId}')">수정</button>
                                <button class="action-btn delete-btn" onclick="deleteAttack('${attack.attackId}', '${defenceId}')">삭제</button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="attack-edit-mode" id="attack-edit-${attack.attackId}">
                    <div class="edit-form">
                        <div class="edit-monsters-row">
                            <div class="edit-pill-input">
                                <input type="text" id="edit-monA-${attack.attackId}" value="${attack.attackMonsterA?.monsterName || ''}" placeholder="몬스터A">
                            </div>
                            <div class="edit-pill-input">
                                <input type="text" id="edit-monB-${attack.attackId}" value="${attack.attackMonsterB?.monsterName || ''}" placeholder="몬스터B">
                            </div>
                            <div class="edit-pill-input">
                                <input type="text" id="edit-monC-${attack.attackId}" value="${attack.attackMonsterC?.monsterName || ''}" placeholder="몬스터C">
                            </div>
                        </div>
                        <div class="edit-desc-group">
                            <div class="edit-desc-row">
                                <label class="edit-desc-label">비고1</label>
                                <textarea class="edit-desc-textarea" id="edit-desc1-${attack.attackId}">${attack.deckDesc1 || ''}</textarea>
                            </div>
                            <div class="edit-desc-row">
                                <label class="edit-desc-label">비고2</label>
                                <textarea class="edit-desc-textarea" id="edit-desc2-${attack.attackId}">${attack.deckDesc2 || ''}</textarea>
                            </div>
                        </div>
                        <div class="edit-actions">
                            <button class="action-btn btn-cancel" onclick="disableAttackEdit('${attack.attackId}')">취소</button>
                            <button class="action-btn btn-save" onclick="saveAttackEdit('${attack.attackId}', '${defenceId}')">저장</button>
                        </div>
                    </div>
                </div>
            </div>
        `).join('');
    }

    function enableAttackEdit(attackId) {
        document.getElementById(`attack-view-${attackId}`).style.display = 'none';
        document.getElementById(`attack-edit-${attackId}`).style.display = 'block';
    }

    function disableAttackEdit(attackId) {
        document.getElementById(`attack-view-${attackId}`).style.display = 'block';
        document.getElementById(`attack-edit-${attackId}`).style.display = 'none';
    }

    async function saveAttackEdit(attackId, defenceId) {
        const monsterA = document.getElementById(`edit-monA-${attackId}`).value.trim();
        const monsterB = document.getElementById(`edit-monB-${attackId}`).value.trim();
        const monsterC = document.getElementById(`edit-monC-${attackId}`).value.trim();
        const deckDesc1 = document.getElementById(`edit-desc1-${attackId}`).value.trim();
        const deckDesc2 = document.getElementById(`edit-desc2-${attackId}`).value.trim();

        try {
            const response = await fetch(`/api/admin/attack/${attackId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ monsterA, monsterB, monsterC, deckDesc1, deckDesc2 }),
                credentials: 'include'
            });

            if (response.ok) {
                alert('저장되었습니다.');
                fetchAttackList(defenceId);
            } else {
                alert('저장에 실패했습니다.');
            }
        } catch (error) {
            console.error('Failed to save attack:', error);
            alert('오류가 발생했습니다.');
        }
    }

    async function deleteAttack(attackId, defenceId) {
        if (!confirm('공략을 삭제하시겠습니까?')) return;

        try {
            const response = await fetch(`/api/admin/attack/${attackId}`, {
                method: 'DELETE',
                credentials: 'include'
            });

            if (response.ok) {
                alert('삭제되었습니다.');
                fetchAttackList(defenceId);
            } else {
                let errMsg = "삭제에 실패했습니다."
                if(response.status === 403){
                    errMsg = "권한이 없습니다."
                }
                alert(errMsg);
            }
        } catch (error) {
            console.error('Failed to delete attack:', error);
            alert('오류가 발생했습니다.');
        }
    }

    function renderMonster(monster) {
        if (!monster || !monster.monsterName) return '';
        const typeIcon = monster.typeImg
            ? `<img class="monster-type-icon" src="/public/image/${monster.typeImg}" alt="${monster.typeName || ''}">`
            : '';

        return `
            <div class="monster-pill">
                <span class="monster-name ${monster.typeColor || ''}">${typeIcon}${monster.monsterName}</span>
            </div>
        `;
    }

    function editDefence(defenceId) {
        // TODO: 수정 모달 또는 페이지 이동
        console.log('Edit defence:', defenceId);
        alert('수정 기능 구현 예정: ' + defenceId);
    }

    async function deleteDefence(defenceId) {
        if (!confirm('정말 삭제하시겠습니까?')) return;

        try {
            const response = await fetch(`/api/admin/defence/${defenceId}`, {
                method: 'DELETE',
                credentials: 'include'
            });

            if (response.ok) {
                alert('삭제되었습니다.');
                fetchDefenceList();
            } else {
                const data = await response.json();
                alert(data.message || '삭제에 실패했습니다.');
            }
        } catch (error) {
            console.error('Failed to delete defence:', error);
            alert('삭제 중 오류가 발생했습니다.');
        }
    }

    fetchDefenceList();

    // 롱프레스 팝업 기능
    let longPressTimer = null;
    const LONG_PRESS_DURATION = 2000;
    const popup = document.getElementById('monsterPopup');
    const popupList = document.getElementById('monsterPopupList');

    function showMonsterPopup(e, defenceData) {
        if (!defenceData) return;

        const monsters = [
            defenceData.monsterA,
            defenceData.monsterB,
            defenceData.monsterC
        ].filter(m => m && m.monsterName);

        if (monsters.length === 0) return;

        popupList.innerHTML = monsters.map(m => {
            const icon = m.typeImg ? `<img src="/public/image/${m.typeImg}" alt="">` : '';
            return `<div class="monster-popup-item">${icon}${m.monsterName}</div>`;
        }).join('');

        // 팝업 위치 설정
        const rect = e.target.getBoundingClientRect();
        popup.style.left = `${rect.left}px`;
        popup.style.top = `${rect.bottom + 8}px`;

        // 화면 밖으로 나가면 조정
        setTimeout(() => {
            const popupRect = popup.getBoundingClientRect();
            if (popupRect.right > window.innerWidth) {
                popup.style.left = `${window.innerWidth - popupRect.width - 10}px`;
            }
            if (popupRect.bottom > window.innerHeight) {
                popup.style.top = `${rect.top - popupRect.height - 8}px`;
            }
        }, 0);

        popup.classList.add('show');
    }

    function hideMonsterPopup() {
        popup.classList.remove('show');
    }

    function getDefenceDataFromElement(element) {
        const monsterDeck = element.closest('.monster-deck');
        if (!monsterDeck || !monsterDeck.dataset.defence) return null;
        try {
            return JSON.parse(monsterDeck.dataset.defence);
        } catch {
            return null;
        }
    }

    // 이벤트 위임으로 롱프레스 처리
    document.addEventListener('mousedown', (e) => {
        const monsterName = e.target.closest('.monster-name');
        if (!monsterName) return;

        const defenceData = getDefenceDataFromElement(monsterName);
        if (!defenceData) return;

        longPressTimer = setTimeout(() => {
            showMonsterPopup(e, defenceData);
        }, LONG_PRESS_DURATION);
    });

    document.addEventListener('mouseup', () => {
        if (longPressTimer) {
            clearTimeout(longPressTimer);
            longPressTimer = null;
        }
    });

    document.addEventListener('mouseleave', () => {
        if (longPressTimer) {
            clearTimeout(longPressTimer);
            longPressTimer = null;
        }
    });

    // 터치 이벤트 (모바일)
    document.addEventListener('touchstart', (e) => {
        const monsterName = e.target.closest('.monster-name');
        if (!monsterName) return;

        const defenceData = getDefenceDataFromElement(monsterName);
        if (!defenceData) return;

        longPressTimer = setTimeout(() => {
            showMonsterPopup(e.touches[0], defenceData);
        }, LONG_PRESS_DURATION);
    });

    document.addEventListener('touchend', () => {
        if (longPressTimer) {
            clearTimeout(longPressTimer);
            longPressTimer = null;
        }
    });

    document.addEventListener('touchmove', () => {
        if (longPressTimer) {
            clearTimeout(longPressTimer);
            longPressTimer = null;
        }
    });

    // 다른 영역 클릭 시 팝업 숨김
    document.addEventListener('click', (e) => {
        if (!popup.contains(e.target) && !e.target.closest('.monster-name')) {
            hideMonsterPopup();
        }
    });
</script>
</body>
</html>
