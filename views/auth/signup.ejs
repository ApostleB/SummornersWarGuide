<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>회원가입 - Summorners</title>
    <link rel="stylesheet" href="/css/common/layout.css">
    <link rel="stylesheet" href="/css/auth/index.css">
</head>
<body>
    <%- include('../partials/header') %>

    <main class="main-content auth-page">
        <div class="auth-container">
            <div class="auth-header">
                <h1>회원가입</h1>
                <p>새 계정을 만들어 시작하세요</p>
            </div>

            <div class="message" id="message"></div>

            <form id="signupForm">
                <div class="form-group">
                    <label for="email">이메일</label>
                    <input type="email" id="email" name="email" placeholder="이메일을 입력하세요" required>
                </div>

                <div class="form-group">
                    <label for="name">이름</label>
                    <input type="text" id="name" name="name" placeholder="이름을 입력하세요" required>
                </div>

                <div class="form-group">
                    <label for="password">비밀번호</label>
                    <input type="password" id="password" name="password" placeholder="비밀번호를 입력하세요" required minlength="6">
                    <div class="hint">최소 6자 이상 입력하세요</div>
                </div>

                <div class="form-group">
                    <label for="confirmPassword">비밀번호 확인</label>
                    <input type="password" id="confirmPassword" name="confirmPassword" placeholder="비밀번호를 다시 입력하세요" required>
                </div>

                <div class="form-group">
                    <label for="regCode">가입 코드 (선택)</label>
                    <input type="text" id="regCode" name="regCode" placeholder="가입 코드가 있다면 입력하세요">
                    <div class="hint">길드장에게 받은 코드를 입력하세요</div>
                </div>

                <button type="submit" class="btn-auth">회원가입</button>
            </form>

            <div class="auth-link">
                이미 계정이 있으신가요? <a href="/auth/login">로그인</a>
            </div>
        </div>
    </main>

    <script>
        document.getElementById('signupForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const email = document.getElementById('email').value;
            const name = document.getElementById('name').value;
            const password = document.getElementById('password').value;
            const confirmPassword = document.getElementById('confirmPassword').value;
            const regCode = document.getElementById('regCode').value;
            const message = document.getElementById('message');

            if (password !== confirmPassword) {
                message.textContent = '비밀번호가 일치하지 않습니다.';
                message.className = 'message error show';
                return;
            }

            try {
                const body = { email, password, name };
                if (regCode) {
                    body.regCode = regCode;
                }

                const response = await fetch('/api/auth/signup', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(body),
                });

                const data = await response.json();

                if (response.ok) {
                    message.textContent = data.message;
                    message.className = 'message success show';
                    setTimeout(() => {
                        window.location.href = '/auth/login';
                    }, 2000);
                } else {
                    message.textContent = data.message || '회원가입에 실패했습니다.';
                    message.className = 'message error show';
                }
            } catch (error) {
                message.textContent = '서버 오류가 발생했습니다.';
                message.className = 'message error show';
            }
        });
    </script>
</body>
</html>
